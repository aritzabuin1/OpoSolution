# Supabase — crear proyecto en https://supabase.com (región EU para GDPR)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (para embeddings text-embedding-3-small) — https://platform.openai.com
OPENAI_API_KEY=sk-...

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs de precios (crear productos en Stripe Dashboard)
# --- AGE C2 + C1 ---
STRIPE_PRICE_PACK=price_...          # Pack Auxiliar C2  49.99€ → +20 análisis
STRIPE_PRICE_PACK_C1=price_...       # Pack Admin C1     49.99€ → +20 análisis
STRIPE_PRICE_PACK_DOBLE=price_...    # Pack Doble C2+C1  79.99€ → +30 análisis
# --- AGE A2 (GACE) ---
STRIPE_PRICE_PACK_A2=price_...       # Pack GACE A2      69.99€ → +20 análisis + 5 supuestos
STRIPE_PRICE_PACK_TRIPLE=price_...   # Pack Triple AGE   129.99€ → +40 análisis + 5 supuestos
STRIPE_PRICE_RECARGA_SUP=price_...   # Recarga supuestos 14.99€ → +5 supuestos prácticos
# --- Recargas y Fundador ---
STRIPE_PRICE_RECARGA=price_...       # Recarga análisis  8.99€ → +10 análisis
STRIPE_PRICE_FOUNDER=price_...       # Pack Fundador     24.99€ → +30 análisis + 5 supuestos + badge

# Sentry — desactivado (incompatible con Turbopack). Descomentar cuando soporte Turbopack.
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=oporuta

# Upstash Redis (rate limiting) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (email alertas de coste) — https://resend.com
RESEND_API_KEY=re_...
ALERT_EMAIL=tu@email.com

# Cron — secreto aleatorio para autenticar llamadas de Vercel Cron
CRON_SECRET=your-random-secret-min-32-chars

# URL publica de la app (usada en emails, OG images, etc.)
NEXT_PUBLIC_APP_URL=https://oporuta.es

# Meta Pixel — https://business.facebook.com/events_manager
# NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# Email del admin (para alertas de coste y feedback)
ADMIN_EMAIL=admin@oporuta.es

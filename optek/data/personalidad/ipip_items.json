  "items": [
    {"id": "O1_01", "texto": "Tengo una imaginacion muy activa", "dimension": "O", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "O1_02", "texto": "Disfruto dejandome llevar por mis fantasias", "dimension": "O", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "O1_03", "texto": "Me gusta imaginar soluciones creativas a los problemas", "dimension": "O", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "O1_04", "texto": "Con frecuencia visualizo escenarios futuros", "dimension": "O", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "O1_05", "texto": "Rara vez fantaseo", "dimension": "O", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "O1_06", "texto": "No tengo buena imaginacion", "dimension": "O", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "O1_07", "texto": "Prefiero atenerme a los hechos antes que imaginar posibilidades", "dimension": "O", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "O1_08", "texto": "No me interesa sonar despierto", "dimension": "O", "faceta": 1, "reversed": true, "validez_type": null},

    {"id": "O2_01", "texto": "Creo en la importancia del arte", "dimension": "O", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "O2_02", "texto": "Me atraen los patrones esteticos", "dimension": "O", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "O2_03", "texto": "Disfruto visitando museos y exposiciones", "dimension": "O", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "O2_04", "texto": "La belleza en la naturaleza me conmueve profundamente", "dimension": "O", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "O2_05", "texto": "No me interesa el arte", "dimension": "O", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "O2_06", "texto": "Rara vez aprecio la belleza artistica", "dimension": "O", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "O2_07", "texto": "No veo el sentido de ir a conciertos o exposiciones", "dimension": "O", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "O2_08", "texto": "La poesia me deja indiferente", "dimension": "O", "faceta": 2, "reversed": true, "validez_type": null},

    {"id": "O3_01", "texto": "Experimento mis emociones intensamente", "dimension": "O", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "O3_02", "texto": "Me conmuevo facilmente con las historias de los demas", "dimension": "O", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "O3_03", "texto": "Siento las emociones de forma muy profunda", "dimension": "O", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "O3_04", "texto": "Me emociono facilmente con peliculas o libros", "dimension": "O", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "O3_05", "texto": "Rara vez me emociono con lo que me rodea", "dimension": "O", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "O3_06", "texto": "No suelo experimentar emociones fuertes", "dimension": "O", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "O3_07", "texto": "Me considero una persona poco emotiva", "dimension": "O", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "O3_08", "texto": "Las situaciones sentimentales no me afectan mucho", "dimension": "O", "faceta": 3, "reversed": true, "validez_type": null},

    {"id": "O4_01", "texto": "Prefiero la variedad a la rutina", "dimension": "O", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "O4_02", "texto": "Me gustan los retos nuevos", "dimension": "O", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "O4_03", "texto": "Disfruto explorando lugares desconocidos", "dimension": "O", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "O4_04", "texto": "Busco experiencias nuevas y diferentes", "dimension": "O", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "O4_05", "texto": "Prefiero seguir una rutina establecida", "dimension": "O", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "O4_06", "texto": "No me gusta probar cosas nuevas", "dimension": "O", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "O4_07", "texto": "Me siento mas comodo con lo conocido", "dimension": "O", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "O4_08", "texto": "Los cambios me generan incomodidad", "dimension": "O", "faceta": 4, "reversed": true, "validez_type": null},

    {"id": "O5_01", "texto": "Disfruto pensando en teorias abstractas", "dimension": "O", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "O5_02", "texto": "Me interesa analizar ideas complejas", "dimension": "O", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "O5_03", "texto": "Me gusta resolver problemas que requieren mucha reflexion", "dimension": "O", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "O5_04", "texto": "Las discusiones filosoficas me resultan estimulantes", "dimension": "O", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "O5_05", "texto": "No me atraen las ideas abstractas", "dimension": "O", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "O5_06", "texto": "Evito las conversaciones intelectuales", "dimension": "O", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "O5_07", "texto": "Prefiero lo practico a lo teorico", "dimension": "O", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "O5_08", "texto": "No me interesan las cuestiones filosoficas", "dimension": "O", "faceta": 5, "reversed": true, "validez_type": null},

    {"id": "O6_01", "texto": "Creo que las leyes deben adaptarse a los tiempos", "dimension": "O", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "O6_02", "texto": "Pienso que la sociedad debe estar abierta al cambio", "dimension": "O", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "O6_03", "texto": "Considero que las normas sociales deben revisarse periodicamente", "dimension": "O", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "O6_04", "texto": "Creo que hay muchas formas validas de ver el mundo", "dimension": "O", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "O6_05", "texto": "Creo que la tradicion es la mejor guia", "dimension": "O", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "O6_06", "texto": "Los valores tradicionales son los que mejor funcionan", "dimension": "O", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "O6_07", "texto": "La autoridad debe respetarse sin cuestionarla", "dimension": "O", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "O6_08", "texto": "Las cosas funcionaban mejor en el pasado", "dimension": "O", "faceta": 6, "reversed": true, "validez_type": null},

    {"id": "C1_01", "texto": "Completo las tareas con exito", "dimension": "C", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "C1_02", "texto": "Se manejar bien las situaciones dificiles", "dimension": "C", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "C1_03", "texto": "Confio en mi capacidad para resolver problemas", "dimension": "C", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "C1_04", "texto": "Me siento preparado para afrontar cualquier reto", "dimension": "C", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "C1_05", "texto": "Dudo de mis propias habilidades", "dimension": "C", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "C1_06", "texto": "A menudo siento que no estoy a la altura", "dimension": "C", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "C1_07", "texto": "Me cuesta tomar decisiones importantes", "dimension": "C", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "C1_08", "texto": "Con frecuencia me siento inseguro sobre lo que hago", "dimension": "C", "faceta": 1, "reversed": true, "validez_type": null},

    {"id": "C2_01", "texto": "Mantengo mis cosas ordenadas", "dimension": "C", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "C2_02", "texto": "Sigo un horario estricto", "dimension": "C", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "C2_03", "texto": "Me gusta que cada cosa este en su sitio", "dimension": "C", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "C2_04", "texto": "Organizo mi espacio de trabajo con esmero", "dimension": "C", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "C2_05", "texto": "Suelo tener desorden a mi alrededor", "dimension": "C", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "C2_06", "texto": "No me importa si las cosas estan desordenadas", "dimension": "C", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "C2_07", "texto": "Olvido donde dejo mis cosas", "dimension": "C", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "C2_08", "texto": "Mi escritorio suele estar lleno de papeles sin organizar", "dimension": "C", "faceta": 2, "reversed": true, "validez_type": null},

    {"id": "C3_01", "texto": "Cumplo mis promesas", "dimension": "C", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "C3_02", "texto": "Sigo las normas establecidas", "dimension": "C", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "C3_03", "texto": "Siempre intento hacer lo correcto", "dimension": "C", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "C3_04", "texto": "Me tomo en serio mis obligaciones", "dimension": "C", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "C3_05", "texto": "A veces incumplo mis compromisos", "dimension": "C", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "C3_06", "texto": "No siempre sigo las reglas al pie de la letra", "dimension": "C", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "C3_07", "texto": "A veces dejo de lado mis responsabilidades", "dimension": "C", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "C3_08", "texto": "Me cuesta cumplir con lo que prometo", "dimension": "C", "faceta": 3, "reversed": true, "validez_type": null},

    {"id": "C4_01", "texto": "Trabajo duro para conseguir mis metas", "dimension": "C", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "C4_02", "texto": "Me esfuerzo por la excelencia en todo lo que hago", "dimension": "C", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "C4_03", "texto": "Me fijo metas ambiciosas", "dimension": "C", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "C4_04", "texto": "No descanso hasta lograr lo que me propongo", "dimension": "C", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "C4_05", "texto": "Me conformo con lo minimo necesario", "dimension": "C", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "C4_06", "texto": "No tengo grandes ambiciones", "dimension": "C", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "C4_07", "texto": "Hago solo lo justo para salir del paso", "dimension": "C", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "C4_08", "texto": "No me preocupa ser el mejor en lo que hago", "dimension": "C", "faceta": 4, "reversed": true, "validez_type": null},

    {"id": "C5_01", "texto": "Termino lo que empiezo", "dimension": "C", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "C5_02", "texto": "Me pongo manos a la obra inmediatamente", "dimension": "C", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "C5_03", "texto": "Mantengo la concentracion en mis tareas", "dimension": "C", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "C5_04", "texto": "Soy constante en mis esfuerzos", "dimension": "C", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "C5_05", "texto": "Dejo las tareas a medias con frecuencia", "dimension": "C", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "C5_06", "texto": "Me distraigo facilmente cuando trabajo", "dimension": "C", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "C5_07", "texto": "Postergo las tareas importantes", "dimension": "C", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "C5_08", "texto": "Me cuesta mantener el ritmo de trabajo", "dimension": "C", "faceta": 5, "reversed": true, "validez_type": null},

    {"id": "C6_01", "texto": "Pienso antes de actuar", "dimension": "C", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "C6_02", "texto": "Planifico con antelacion", "dimension": "C", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "C6_03", "texto": "Evaluo las consecuencias antes de tomar una decision", "dimension": "C", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "C6_04", "texto": "Me preparo cuidadosamente para las situaciones importantes", "dimension": "C", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "C6_05", "texto": "Actuo sin pensar en las consecuencias", "dimension": "C", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "C6_06", "texto": "Tomo decisiones de forma impulsiva", "dimension": "C", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "C6_07", "texto": "Rara vez planifico con antelacion", "dimension": "C", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "C6_08", "texto": "Me lanzo a las cosas sin prepararme", "dimension": "C", "faceta": 6, "reversed": true, "validez_type": null},

    {"id": "E1_01", "texto": "Hago amigos facilmente", "dimension": "E", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "E1_02", "texto": "Me siento comodo con la gente", "dimension": "E", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "E1_03", "texto": "Me resulta facil entablar conversacion con desconocidos", "dimension": "E", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "E1_04", "texto": "Caigo bien a la mayoria de la gente", "dimension": "E", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "E1_05", "texto": "Me cuesta hacer nuevos amigos", "dimension": "E", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "E1_06", "texto": "Me siento incomodo en situaciones sociales nuevas", "dimension": "E", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "E1_07", "texto": "Tardo mucho en sentirme a gusto con personas nuevas", "dimension": "E", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "E1_08", "texto": "Soy reservado con la gente que no conozco bien", "dimension": "E", "faceta": 1, "reversed": true, "validez_type": null},

    {"id": "E2_01", "texto": "Me encanta estar rodeado de gente", "dimension": "E", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "E2_02", "texto": "Disfruto de las fiestas y reuniones sociales", "dimension": "E", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "E2_03", "texto": "Busco la compania de los demas", "dimension": "E", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "E2_04", "texto": "Me siento mejor cuando estoy acompanado", "dimension": "E", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "E2_05", "texto": "Prefiero pasar tiempo a solas", "dimension": "E", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "E2_06", "texto": "Las reuniones sociales me agotan", "dimension": "E", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "E2_07", "texto": "Evito las grandes aglomeraciones de gente", "dimension": "E", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "E2_08", "texto": "No me gustan las fiestas", "dimension": "E", "faceta": 2, "reversed": true, "validez_type": null},

    {"id": "E3_01", "texto": "Tomo el mando en las situaciones de grupo", "dimension": "E", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "E3_02", "texto": "Tengo facilidad para influir en los demas", "dimension": "E", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "E3_03", "texto": "Me siento comodo dando ordenes cuando es necesario", "dimension": "E", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "E3_04", "texto": "Expreso mis opiniones con firmeza", "dimension": "E", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "E3_05", "texto": "Dejo que otros tomen las decisiones por mi", "dimension": "E", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "E3_06", "texto": "Me cuesta expresar mi opinion en grupo", "dimension": "E", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "E3_07", "texto": "Evito asumir el rol de lider", "dimension": "E", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "E3_08", "texto": "Me resulta dificil defender mi punto de vista", "dimension": "E", "faceta": 3, "reversed": true, "validez_type": null},

    {"id": "E4_01", "texto": "Estoy siempre ocupado", "dimension": "E", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "E4_02", "texto": "Tengo un ritmo de vida rapido", "dimension": "E", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "E4_03", "texto": "Siempre tengo algo que hacer", "dimension": "E", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "E4_04", "texto": "Me muevo con energia y rapidez", "dimension": "E", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "E4_05", "texto": "Llevo un ritmo de vida tranquilo", "dimension": "E", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "E4_06", "texto": "Prefiero tomarme las cosas con calma", "dimension": "E", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "E4_07", "texto": "No tengo prisa por hacer las cosas", "dimension": "E", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "E4_08", "texto": "Me gusta tener tiempo libre sin hacer nada", "dimension": "E", "faceta": 4, "reversed": true, "validez_type": null},

    {"id": "E5_01", "texto": "Me atraen las experiencias intensas", "dimension": "E", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "E5_02", "texto": "Disfruto con la adrenalina", "dimension": "E", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "E5_03", "texto": "Me gustan los deportes de riesgo", "dimension": "E", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "E5_04", "texto": "Busco situaciones emocionantes", "dimension": "E", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "E5_05", "texto": "Evito las situaciones de riesgo", "dimension": "E", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "E5_06", "texto": "Prefiero actividades tranquilas y seguras", "dimension": "E", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "E5_07", "texto": "No me atraen las emociones fuertes", "dimension": "E", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "E5_08", "texto": "Me asusta la velocidad excesiva", "dimension": "E", "faceta": 5, "reversed": true, "validez_type": null},

    {"id": "E6_01", "texto": "Irradio alegria", "dimension": "E", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "E6_02", "texto": "Me siento lleno de energia positiva", "dimension": "E", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "E6_03", "texto": "Me rio con facilidad", "dimension": "E", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "E6_04", "texto": "Transmito buen humor a los que me rodean", "dimension": "E", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "E6_05", "texto": "No soy una persona especialmente alegre", "dimension": "E", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "E6_06", "texto": "Rara vez siento entusiasmo", "dimension": "E", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "E6_07", "texto": "No me considero una persona divertida", "dimension": "E", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "E6_08", "texto": "Me cuesta sentir alegria intensa", "dimension": "E", "faceta": 6, "reversed": true, "validez_type": null},

    {"id": "A1_01", "texto": "Creo que la gente es basicamente honesta", "dimension": "A", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "A1_02", "texto": "Confio en los demas", "dimension": "A", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "A1_03", "texto": "Creo en las buenas intenciones de la gente", "dimension": "A", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "A1_04", "texto": "Tiendo a dar el beneficio de la duda a los demas", "dimension": "A", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "A1_05", "texto": "Desconfio de las intenciones de los demas", "dimension": "A", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "A1_06", "texto": "Sospecho que la gente tiene motivos ocultos", "dimension": "A", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "A1_07", "texto": "Creo que la mayoria de la gente mentiria si le conviniera", "dimension": "A", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "A1_08", "texto": "Me cuesta confiar en personas que acabo de conocer", "dimension": "A", "faceta": 1, "reversed": true, "validez_type": null},

    {"id": "A2_01", "texto": "No intento manipular a los demas", "dimension": "A", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "A2_02", "texto": "Soy sincero en mis relaciones", "dimension": "A", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "A2_03", "texto": "Digo la verdad aunque no me beneficie", "dimension": "A", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "A2_04", "texto": "Prefiero ser honesto a quedar bien", "dimension": "A", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "A2_05", "texto": "A veces utilizo la adulacion para conseguir lo que quiero", "dimension": "A", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "A2_06", "texto": "Oculto informacion si me conviene", "dimension": "A", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "A2_07", "texto": "Se como enganar a la gente si es necesario", "dimension": "A", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "A2_08", "texto": "Exagero mis logros para impresionar a los demas", "dimension": "A", "faceta": 2, "reversed": true, "validez_type": null},

    {"id": "A3_01", "texto": "Ayudo a los demas desinteresadamente", "dimension": "A", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "A3_02", "texto": "Me preocupo por el bienestar ajeno", "dimension": "A", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "A3_03", "texto": "Disfruto haciendo favores a los demas", "dimension": "A", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "A3_04", "texto": "Dedico tiempo a ayudar a quienes lo necesitan", "dimension": "A", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "A3_05", "texto": "No me gusta que me pidan favores", "dimension": "A", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "A3_06", "texto": "Prefiero ocuparme de mis propios asuntos", "dimension": "A", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "A3_07", "texto": "No suelo preocuparme por los problemas ajenos", "dimension": "A", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "A3_08", "texto": "Solo ayudo cuando obtengo algo a cambio", "dimension": "A", "faceta": 3, "reversed": true, "validez_type": null},

    {"id": "A4_01", "texto": "Evito las confrontaciones", "dimension": "A", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "A4_02", "texto": "Cedo para evitar conflictos", "dimension": "A", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "A4_03", "texto": "Busco el consenso en las discusiones", "dimension": "A", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "A4_04", "texto": "Intento que todos se sientan incluidos en las decisiones", "dimension": "A", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "A4_05", "texto": "No me importa discutir para defender mi postura", "dimension": "A", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "A4_06", "texto": "Me gusta debatir y ganar argumentos", "dimension": "A", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "A4_07", "texto": "Insisto en mis ideas aunque genere conflicto", "dimension": "A", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "A4_08", "texto": "Disfruto de una buena discusion", "dimension": "A", "faceta": 4, "reversed": true, "validez_type": null},

    {"id": "A5_01", "texto": "No me considero mejor que los demas", "dimension": "A", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "A5_02", "texto": "Soy humilde sobre mis logros", "dimension": "A", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "A5_03", "texto": "No me gusta presumir de lo que tengo", "dimension": "A", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "A5_04", "texto": "Reconozco que tengo tanto que aprender como cualquiera", "dimension": "A", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "A5_05", "texto": "Creo que soy mejor que la mayoria de la gente", "dimension": "A", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "A5_06", "texto": "Me gusta que reconozcan mi superioridad", "dimension": "A", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "A5_07", "texto": "Tiendo a hablar de mis exitos", "dimension": "A", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "A5_08", "texto": "Me siento superior a muchas personas", "dimension": "A", "faceta": 5, "reversed": true, "validez_type": null},

    {"id": "A6_01", "texto": "Me compadezco de los que sufren", "dimension": "A", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "A6_02", "texto": "Empatizo con las personas sin hogar", "dimension": "A", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "A6_03", "texto": "Me afectan las desgracias de los demas", "dimension": "A", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "A6_04", "texto": "Siento pena por quienes pasan por dificultades", "dimension": "A", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "A6_05", "texto": "Creo que cada uno tiene lo que se merece", "dimension": "A", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "A6_06", "texto": "No me conmueven facilmente las desgracias ajenas", "dimension": "A", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "A6_07", "texto": "Pienso que la gente exagera sus problemas", "dimension": "A", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "A6_08", "texto": "No siento la necesidad de consolar a los demas", "dimension": "A", "faceta": 6, "reversed": true, "validez_type": null},

    {"id": "N1_01", "texto": "Me preocupo por las cosas con frecuencia", "dimension": "N", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "N1_02", "texto": "Me pongo nervioso facilmente", "dimension": "N", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "N1_03", "texto": "Tiendo a anticipar lo peor", "dimension": "N", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "N1_04", "texto": "Me cuesta dejar de darle vueltas a los problemas", "dimension": "N", "faceta": 1, "reversed": false, "validez_type": null},
    {"id": "N1_05", "texto": "Rara vez me siento ansioso", "dimension": "N", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "N1_06", "texto": "No me preocupo por cosas que podrian salir mal", "dimension": "N", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "N1_07", "texto": "Me mantengo tranquilo en situaciones de incertidumbre", "dimension": "N", "faceta": 1, "reversed": true, "validez_type": null},
    {"id": "N1_08", "texto": "Afronto las dificultades sin agobiarme", "dimension": "N", "faceta": 1, "reversed": true, "validez_type": null},

    {"id": "N2_01", "texto": "Me irrito facilmente", "dimension": "N", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "N2_02", "texto": "Pierdo los nervios con frecuencia", "dimension": "N", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "N2_03", "texto": "Me enfado cuando las cosas no salen como quiero", "dimension": "N", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "N2_04", "texto": "Me resulta dificil controlar mi mal genio", "dimension": "N", "faceta": 2, "reversed": false, "validez_type": null},
    {"id": "N2_05", "texto": "Rara vez me enfado", "dimension": "N", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "N2_06", "texto": "Mantengo la calma incluso cuando me provocan", "dimension": "N", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "N2_07", "texto": "No me molesto por cosas insignificantes", "dimension": "N", "faceta": 2, "reversed": true, "validez_type": null},
    {"id": "N2_08", "texto": "Controlo bien mi temperamento", "dimension": "N", "faceta": 2, "reversed": true, "validez_type": null},

    {"id": "N3_01", "texto": "A menudo me siento triste", "dimension": "N", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "N3_02", "texto": "Me desanimo con facilidad", "dimension": "N", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "N3_03", "texto": "A veces siento que nada tiene sentido", "dimension": "N", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "N3_04", "texto": "Me siento infeliz con frecuencia", "dimension": "N", "faceta": 3, "reversed": false, "validez_type": null},
    {"id": "N3_05", "texto": "Rara vez me siento triste o melancolico", "dimension": "N", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "N3_06", "texto": "Me recupero rapido de los malos momentos", "dimension": "N", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "N3_07", "texto": "Generalmente me siento satisfecho con mi vida", "dimension": "N", "faceta": 3, "reversed": true, "validez_type": null},
    {"id": "N3_08", "texto": "No me dejo hundir por las dificultades", "dimension": "N", "faceta": 3, "reversed": true, "validez_type": null},

    {"id": "N4_01", "texto": "Me siento incomodo siendo el centro de atencion", "dimension": "N", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "N4_02", "texto": "Me averguenzo facilmente", "dimension": "N", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "N4_03", "texto": "Me preocupa lo que los demas piensen de mi", "dimension": "N", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "N4_04", "texto": "Me siento cohibido ante personas que no conozco", "dimension": "N", "faceta": 4, "reversed": false, "validez_type": null},
    {"id": "N4_05", "texto": "No me importa que la gente me mire", "dimension": "N", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "N4_06", "texto": "Me siento comodo hablando en publico", "dimension": "N", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "N4_07", "texto": "No me preocupa la opinion de los demas sobre mi", "dimension": "N", "faceta": 4, "reversed": true, "validez_type": null},
    {"id": "N4_08", "texto": "Me siento a gusto en situaciones sociales formales", "dimension": "N", "faceta": 4, "reversed": true, "validez_type": null},

    {"id": "N5_01", "texto": "Me cuesta resistir las tentaciones", "dimension": "N", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "N5_02", "texto": "A veces como demasiado", "dimension": "N", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "N5_03", "texto": "Gasto mas dinero del que deberia", "dimension": "N", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "N5_04", "texto": "Me dejo llevar por mis impulsos", "dimension": "N", "faceta": 5, "reversed": false, "validez_type": null},
    {"id": "N5_05", "texto": "Controlo bien mis apetitos y deseos", "dimension": "N", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "N5_06", "texto": "Rara vez me excedo en la comida o la bebida", "dimension": "N", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "N5_07", "texto": "Se resistirme a las tentaciones", "dimension": "N", "faceta": 5, "reversed": true, "validez_type": null},
    {"id": "N5_08", "texto": "Tengo un buen autocontrol sobre mis impulsos", "dimension": "N", "faceta": 5, "reversed": true, "validez_type": null},

    {"id": "N6_01", "texto": "Me derrumbo bajo presion", "dimension": "N", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "N6_02", "texto": "Me cuesta manejar el estres", "dimension": "N", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "N6_03", "texto": "Me bloqueo cuando tengo muchas cosas que hacer", "dimension": "N", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "N6_04", "texto": "Me siento abrumado por las situaciones dificiles", "dimension": "N", "faceta": 6, "reversed": false, "validez_type": null},
    {"id": "N6_05", "texto": "Manejo bien la presion", "dimension": "N", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "N6_06", "texto": "Me crezco ante las dificultades", "dimension": "N", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "N6_07", "texto": "Funciono bien en situaciones de emergencia", "dimension": "N", "faceta": 6, "reversed": true, "validez_type": null},
    {"id": "N6_08", "texto": "Rara vez me siento superado por las circunstancias", "dimension": "N", "faceta": 6, "reversed": true, "validez_type": null},

    {"id": "V_SD_01", "texto": "Nunca he dicho una mentira en mi vida", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_02", "texto": "Jamas he sentido envidia de nadie", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_03", "texto": "Siempre actuo de forma completamente justa", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_04", "texto": "Nunca he tenido un pensamiento negativo sobre otra persona", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_05", "texto": "Jamas he roto ninguna norma de trafico", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_06", "texto": "Nunca me he enfadado sin razon", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_07", "texto": "Siempre he sido amable con todo el mundo", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},
    {"id": "V_SD_08", "texto": "Nunca he sentido pereza", "dimension": null, "faceta": null, "reversed": false, "validez_type": "social_desirability"},

    {"id": "V_IF_01", "texto": "Alguna vez he olvidado el nombre de alguien", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_02", "texto": "A veces me siento cansado por la manana", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_03", "texto": "He cometido algun error en mi vida", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_04", "texto": "A veces prefiero estar solo", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_05", "texto": "He sentido nervios antes de un examen", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_06", "texto": "Alguna vez he llegado tarde a una cita", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"},
    {"id": "V_IF_07", "texto": "He cambiado de opinion sobre algo", "dimension": null, "faceta": null, "reversed": false, "validez_type": "infrequency"}

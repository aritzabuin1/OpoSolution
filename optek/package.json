    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "mammoth": "^1.12.0",
    "msw": "^2.12.10",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "word-extractor": "^1.0.4"
  }

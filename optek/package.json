    "ingest:supuestos": "tsx --env-file=.env.local execution/ingest-supuestos-bank.ts",
    "ingest:supuestos-auxilio": "tsx --env-file=.env.local execution/ingest-supuestos-auxilio.ts",
    "ingest:supuestos-tramitacion": "tsx --env-file=.env.local execution/ingest-supuestos-tramitacion.ts",

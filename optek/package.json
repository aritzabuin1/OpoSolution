    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
